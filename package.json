{
  "name": "mega-noughts-and-crosses",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "app"],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w packages/engine && npm run build -w app",
    "test": "npm run test -w packages/engine && npm run test -w app",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "eslint": "^9.6.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.3.2"
  }
}
